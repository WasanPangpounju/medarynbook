# Sanity CMS — Project settings (public, ดูได้จาก sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-15

# Sanity Studio (ต้องตรงกับค่า NEXT_PUBLIC_ ด้านบน)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Sanity API Token — SECRET (ดูได้จาก sanity.io/manage > API > Tokens)
SANITY_API_TOKEN=your_sanity_api_token

# Resend — SECRET (ดูได้จาก resend.com/api-keys)
RESEND_API_KEY=your_resend_api_key
